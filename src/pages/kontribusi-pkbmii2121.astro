---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontribusi Profil PKBM" description="Daftarkan PKBM Anda ke direktori kami dan bantu lebih banyak warga menemukan layanan pendidikan non-formal.">

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --ink:        #1a1a1a;
    --ink-soft:   #555;
    --ink-muted:  #999;
    --paper:      #fdfcf8;
    --paper-2:    #f5f3ed;
    --paper-3:    #eceae2;
    --border:     #dddad0;
    --accent:     #2d6a4f;
    --accent-lt:  #d8f3dc;
    --accent-dk:  #1b4332;
    --danger:     #c0392b;
    --mono:       'DM Mono', 'Fira Mono', monospace;
    --sans:       'DM Sans', 'Nunito', sans-serif;
    --serif:      'DM Serif Display', 'Playfair Display', serif;
  }

  .page {
    min-height: 100vh;
    background: var(--paper);
    font-family: var(--sans);
    color: var(--ink);
    padding-bottom: 4rem;
  }

  .hero {
    background: var(--accent-dk);
    color: #fff;
    padding: 3.5rem 1.5rem 2.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 40%, rgba(45,106,79,.4) 0%, transparent 55%),
      radial-gradient(circle at 80% 70%, rgba(27,67,50,.5) 0%, transparent 55%);
  }
  .hero-inner { position: relative; max-width: 560px; margin: 0 auto; }
  .hero-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 4px;
    padding: 4px 12px;
    margin-bottom: 1.2rem;
    color: rgba(255,255,255,.85);
  }
  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    font-weight: 400;
    line-height: 1.18;
    margin: 0 0 1rem;
    letter-spacing: -.01em;
  }
  .hero p {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,.75);
    margin: 0;
  }

  .form-wrap {
    max-width: 680px;
    margin: 2.5rem auto 0;
    padding: 0 1rem;
  }
  .card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 2px 20px rgba(0,0,0,.05);
  }
  @media (max-width: 520px) { .card { padding: 1.25rem 1rem; } }

  .form-section { margin-bottom: 1.75rem; }
  .section-title {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: .5rem;
    margin: 0 0 1.25rem;
  }
  .field { margin-bottom: 1.1rem; }
  .field:last-child { margin-bottom: 0; }

  label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    margin-bottom: 5px;
  }
  .req { color: var(--accent); margin-left: 2px; }

  input[type="text"],
  input[type="url"],
  input[type="number"],
  textarea {
    width: 100%;
    font-family: var(--sans);
    font-size: 14px;
    padding: 9px 12px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: var(--paper);
    color: var(--ink);
    box-sizing: border-box;
    transition: border-color .15s, box-shadow .15s;
    outline: none;
  }
  input:focus, textarea:focus {
    border-color: var(--accent);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(45,106,79,.1);
  }
  textarea { resize: vertical; min-height: 90px; line-height: 1.6; }

  .hint {
    font-size: 11.5px;
    color: var(--ink-muted);
    margin-top: 5px;
    line-height: 1.5;
  }
  .status-select {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--clr-border, #e2e2dc);
    border-radius: 6px;
    font-size: 0.9rem;
    background: var(--clr-surface, #fff);
    color: var(--clr-text, #1c1c1c);
    cursor: pointer;
  }

  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 440px) { .row2 { grid-template-columns: 1fr; } }

  .chip-group { display: flex; flex-wrap: wrap; gap: 7px; }
  .chip {
    font-size: 12.5px;
    padding: 5px 12px;
    border-radius: 999px;
    cursor: pointer;
    border: 1.5px solid var(--border);
    background: var(--paper-2);
    color: var(--ink-soft);
    user-select: none;
    transition: all .15s;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-lt); }
  .chip.active { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 500; }

  .keung-list { display: flex; flex-direction: column; gap: 7px; }
  .keung-row { display: flex; gap: 6px; align-items: center; }
  .keung-row input { flex: 1; }
  .btn-remove {
    flex-shrink: 0;
    width: 28px; height: 28px;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    background: var(--paper-2);
    color: var(--ink-muted);
    cursor: pointer;
    font-size: 14px;
    display: flex; align-items: center; justify-content: center;
    transition: all .15s;
  }
  .btn-remove:hover { background: #fde8e8; border-color: #e88; color: var(--danger); }
  .btn-add {
    font-size: 12.5px;
    padding: 6px 14px;
    margin-top: 8px;
    cursor: pointer;
    border: 1.5px dashed var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--ink-muted);
    font-family: var(--sans);
    transition: all .15s;
  }
  .btn-add:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-lt); }

  .divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

  .btn-submit {
    width: 100%;
    padding: 13px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    border: none;
    border-radius: 9px;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    letter-spacing: .01em;
    transition: background .15s, transform .1s;
    margin-top: .5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .btn-submit:hover { background: var(--accent-dk); }
  .btn-submit:active { transform: scale(.99); }
  .btn-submit:disabled { opacity: .5; cursor: not-allowed; }

  .spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin .7s linear infinite;
    display: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .status-banner {
    display: none;
    border-radius: 9px;
    padding: 1rem 1.25rem;
    margin-top: 1.25rem;
    font-size: 14px;
    line-height: 1.7;
  }
  .status-banner.success {
    background: var(--accent-lt);
    border: 1px solid rgba(45,106,79,.3);
    color: var(--accent-dk);
  }
  .status-banner.error {
    background: #fde8e8;
    border: 1px solid rgba(192,57,43,.25);
    color: #7b1e1e;
  }
  .status-banner strong { font-weight: 600; }

  .output-section { margin-top: 2rem; }
  .output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .75rem;
  }
  .output-label {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-muted);
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .output-actions { display: flex; gap: 8px; }
  .btn-sm {
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 6px;
    cursor: pointer;
    border: 1.5px solid var(--border);
    background: var(--paper-2);
    color: var(--ink-soft);
    font-family: var(--sans);
    transition: all .15s;
  }
  .btn-sm:hover { background: var(--paper-3); }
  .btn-sm.green { background: var(--accent-lt); border-color: var(--accent); color: var(--accent-dk); }

  .output-box {
    background: var(--ink);
    color: #a8e6bf;
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    max-height: 380px;
    overflow-y: auto;
  }
  .copy-toast {
    font-size: 12px;
    color: var(--accent);
    margin-top: 6px;
    min-height: 18px;
  }

  .info-box {
    background: var(--accent-lt);
    border: 1px solid rgba(45,106,79,.25);
    border-radius: 9px;
    padding: .9rem 1.1rem;
    font-size: 13px;
    color: var(--accent-dk);
    line-height: 1.6;
    margin-bottom: 1.75rem;
  }
  .info-box strong { font-weight: 600; }

  /* ── Upload Foto ── */
  .upload-area {
    border: 2px dashed var(--border);
    border-radius: 10px;
    padding: 1.5rem 1rem;
    text-align: center;
    cursor: pointer;
    background: var(--paper-2);
    transition: border-color .15s, background .15s;
    position: relative;
  }
  .upload-area:hover, .upload-area.dragover {
    border-color: var(--accent);
    background: var(--accent-lt);
  }
  .upload-area input[type="file"] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    border: none; padding: 0;
  }
  .upload-icon { font-size: 2rem; margin-bottom: .4rem; }
  .upload-text { font-size: 13px; color: var(--ink-muted); line-height: 1.5; }
  .upload-text strong { color: var(--accent); }

  .photo-previews {
    display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;
  }
  .photo-thumb {
    position: relative; width: 72px; height: 72px;
  }
  .photo-thumb img {
    width: 72px; height: 72px; object-fit: cover; border-radius: 7px;
    border: 1.5px solid var(--border);
  }
  .photo-thumb .rm-photo {
    position: absolute; top: -6px; right: -6px;
    width: 18px; height: 18px; border-radius: 50%;
    background: #c0392b; color: #fff; border: none;
    font-size: 10px; cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    line-height: 1;
  }
  .upload-count {
    font-size: 11.5px; color: var(--ink-muted); margin-top: 6px;
  }
</style>

<div class="page">

  <div class="hero">
    <div class="hero-inner">
      <div class="hero-tag">Direktori PKBM Islam Indonesia</div>
      <h1>Daftarkan PKBM<br/>ke direktori PKBM Islam Indonesia</h1>
      <p>Isi form berikut — profil akan dikirim langsung ke email admin untuk ditinjau dan di-publish.</p>
    </div>
  </div>

  <div class="form-wrap">
    <div class="card">

      <div class="info-box">
        <strong>Langkah:</strong> Isi form → klik <em>Kirim ke admin</em> → <code style="background:rgba(45,106,79,.15);padding:1px 5px;border-radius:3px;">cek</code> insyaAllah langsung publish.
      </div>

      <!-- 01 Identitas -->
      <div class="form-section">
        <p class="section-title">01 — Identitas PKBM</p>
        <div class="row2">
          <div class="field">
            <label for="nama">Nama PKBM <span class="req">*</span></label>
            <input id="nama" type="text" placeholder="PKBM Luqmanulhakim" autocomplete="organization" />
          </div>
          <div class="field">
            <label>Status Legalitas <span class="required">*</span></label>
            <select id="status" class="status-select">
              <option value="PKBM Mandiri - Akreditasi A">PKBM Mandiri - Akreditasi A</option>
              <option value="PKBM Mandiri - Akreditasi B">PKBM Mandiri - Akreditasi B</option>
              <option value="PKBM Mandiri - Akreditasi C">PKBM Mandiri - Akreditasi C</option>
              <option value="PKBM Mandiri - Belum Akreditasi">PKBM Mandiri - Belum Akreditasi</option>
              <option value="Menginduk">Menginduk ke PKBM lain</option>
              <option value="Homeschooling">Homeschooling</option>
            </select>
          </div>
          <div class="field">
            <label for="tahun">Tahun berdiri</label>
            <input id="tahun" type="number" placeholder="2019" min="1990" max="2099" />
          </div>
        </div>
        <div class="row2">
          <div class="field">
            <label for="kota">Kota / Kabupaten <span class="req">*</span></label>
            <input id="kota" type="text" placeholder="Bogor" />
          </div>
          <div class="field">
            <label for="provinsi">Provinsi <span class="req">*</span></label>
            <input id="provinsi" type="text" placeholder="Jawa Barat" />
          </div>
        </div>
        <!-- field lokasi -->
        <div class="field">
          <label>Link Google Maps <span class="hint">(opsional)</span></label>
          <input type="url" id="maps" placeholder="https://maps.app.goo.gl/..." />
          <p class="hint">Buka Google Maps → cari lokasi → klik Share → salin link pendeknya.</p>
        </div>
        <div class="field">
          <label for="website">Website/Media Sosial <span style="color:var(--ink-muted);font-weight:400;">(opsional)</span></label>
          <input type="text" id="website" placeholder="https://... atau medsos.com/..." />
          <p class="hint">Boleh link website, Instagram, Facebook, atau WhatsApp channel.</p>
        </div>
      </div>

      <!-- 02 Program -->
      <div class="form-section">
        <p class="section-title">02 — Program yang dijalankan</p>
        <div class="field">
          <label>Pilih program <span class="req">*</span></label>
          <div class="chip-group" id="program-chips">
            <span class="chip" data-val="Paket A">Paket A</span>
            <span class="chip" data-val="Paket B">Paket B</span>
            <span class="chip" data-val="Paket C">Paket C</span>
            <span class="chip" data-val="Keterampilan Menjahit">Menjahit</span>
            <span class="chip" data-val="Komputer & TI">Komputer & TI</span>
            <span class="chip" data-val="Kewirausahaan">Kewirausahaan</span>
            <span class="chip" data-val="Tata Boga">Tata Boga</span>
            <span class="chip" data-val="Bahasa Arab & Al-Qur'an">B. Arab & Quran</span>
            <span class="chip" data-val="Tahfidz">Tahfidz</span>
          </div>
        </div>
        <div class="field">
          <label for="program-custom">Program lain</label>
          <input id="program-custom" type="text" placeholder="Tata Rias, Pertanian Organik, … (pisahkan koma)" />
        </div>
      </div>

      <!-- 03 Profil -->
      <div class="form-section">
        <p class="section-title">03 — Profil & Konten</p>
        <div class="field">
          <label for="deskripsi">Deskripsi singkat <span class="req">*</span></label>
          <textarea id="deskripsi" rows="3" placeholder="Satu–dua kalimat singkat tentang PKBM ini..."></textarea>
          <p class="hint">Dipakai untuk meta SEO dan kartu di halaman daftar. Maks. ~200 karakter.</p>
        </div>
        <div class="field">
          <label>Keunggulan PKBM <span style="color:var(--ink-muted);font-weight:400;">(opsional)</span></label>
          <div class="keung-list" id="keung-list">
            <div class="keung-row">
              <input type="text" placeholder="Contoh: Jadwal malam untuk warga belajar yang bekerja" />
              <button class="btn-remove" title="Hapus" id="btn-remove-init">✕</button>
            </div>
          </div>
          <button class="btn-add" id="btn-add-keung">+ Tambah keunggulan</button>
        </div>
        <div class="field">
          <label for="narasi">Narasi / profil lengkap <span class="req">*</span></label>
          <textarea id="narasi" rows="7" placeholder="Tulis narasi lengkap di sini. bisa gunakan tanda:&#10;## Subjudul&#10;**tebal**, *miring*, - list, > kutipan"></textarea>
          <p class="hint">Ini konten utama halaman profil. Tulis bebas, boleh pakai Markdown dasar.</p>
        </div>
      </div>

      <!-- 04 Pengisi -->
      <div class="form-section">
        <p class="section-title">04 — Informasi pengisi</p>
        <div class="field">
          <label for="pengisi">Nama pengisi form <span style="color:var(--ink-muted);font-weight:400;">(opsional)</span></label>
          <input id="pengisi" type="text" placeholder="Ustadz Ahmad / Pengelola PKBM" />
        </div>
      </div>

      <div class="row2">
        <div class="field">
          <label>No. WhatsApp / Telepon</label>
          <input type="text" id="kontak-telp" placeholder="08123456789" />
        </div>
        <div class="field">
          <label>Email (opsional)</label>
          <input type="text" id="kontak-email" placeholder="pkbm@..." />
        </div>
      </div>

      <!-- 05 Foto PKBM -->
      <div class="form-section">
        <p class="section-title">05 — Foto PKBM <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:11px;">(opsional, maks. 5 foto · 5 MB/foto)</span></p>
        <div class="field">
          <div class="upload-area" id="upload-area">
            <input type="file" id="foto-input" accept="image/*" multiple />
            <div class="upload-icon">📷</div>
            <div class="upload-text">
              <strong>Klik atau seret foto ke sini</strong><br>
              JPG, PNG, WebP · maks. 5 foto · 5 MB per foto
            </div>
          </div>
          <div class="photo-previews" id="photo-previews"></div>
          <p class="upload-count" id="upload-count"></p>
          <p class="hint">Foto gedung, ruang belajar, kegiatan warga belajar, dll. Akan disimpan di Google Drive admin.</p>
        </div>
      </div>

      <button class="btn-submit" id="btn-submit">
        <span class="spinner" id="spinner"></span>
        <span id="btn-label">Kirim ke admin</span>
      </button>

      <div class="status-banner" id="status-banner"></div>

      <div id="output-wrap" class="output-section" style="display:none;">
        <hr class="divider" />
        <div class="output-header">
          <span class="output-label" id="output-filename">pkbm-baru.md</span>
          <div class="output-actions">
            <button class="btn-sm" id="btn-copy">Salin</button>
            <button class="btn-sm green" id="btn-dl">⬇ Download .md</button>
          </div>
        </div>
        <div class="output-box" id="output"></div>
        <p class="copy-toast" id="copy-toast"></p>
      </div>

    </div>
  </div>
</div>

<script is:inline>
document.querySelectorAll('#program-chips .chip').forEach(chip => {
    chip.addEventListener('click', () => chip.classList.toggle('active'));
  });
</script>


<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  // ════════════════════════════════════════════════
  // 🔧 GANTI DENGAN URL GOOGLE APPS SCRIPT ANDA
  // ════════════════════════════════════════════════
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzARZLWrocStnlrHbPoVcJJQmpmBeoD0ytTkljAKAr7wTsO_AuO79NXfvocOHxnErIS/exec';
  // ════════════════════════════════════════════════

  // ── Upload Foto ──
  const MAX_PHOTOS = 5;
  const MAX_SIZE_MB = 5;
  let selectedPhotos = []; // Array of { name, base64, type }

  const uploadArea  = document.getElementById('upload-area');
  const fotoInput   = document.getElementById('foto-input');
  const previews    = document.getElementById('photo-previews');
  const countEl     = document.getElementById('upload-count');

  function updateCount() {
    countEl.textContent = selectedPhotos.length > 0
      ? selectedPhotos.length + ' foto dipilih'
      : '';
  }

  function renderPreviews() {
    previews.innerHTML = '';
    selectedPhotos.forEach((p, i) => {
      const thumb = document.createElement('div');
      thumb.className = 'photo-thumb';
      const img = document.createElement('img');
      img.src = 'data:' + p.type + ';base64,' + p.base64;
      img.alt = p.name;
      const rm = document.createElement('button');
      rm.className = 'rm-photo';
      rm.textContent = '✕';
      rm.title = 'Hapus';
      rm.addEventListener('click', () => {
        selectedPhotos.splice(i, 1);
        renderPreviews();
        updateCount();
      });
      thumb.appendChild(img);
      thumb.appendChild(rm);
      previews.appendChild(thumb);
    });
    updateCount();
  }

  async function addFiles(files) {
    const remaining = MAX_PHOTOS - selectedPhotos.length;
    const toAdd = [...files].slice(0, remaining);
    const errors = [];
    for (const file of toAdd) {
      if (!file.type.startsWith('image/')) { errors.push(file.name + ': bukan gambar'); continue; }
      if (file.size > MAX_SIZE_MB * 1024 * 1024) { errors.push(file.name + ': ukuran > ' + MAX_SIZE_MB + 'MB'); continue; }
      const b64 = await new Promise((res, rej) => {
        const r = new FileReader();
        r.onload  = () => res(r.result.split(',')[1]);
        r.onerror = () => rej();
        r.readAsDataURL(file);
      });
      selectedPhotos.push({ name: file.name, base64: b64, type: file.type });
    }
    if (errors.length) alert('Foto dilewati:\n' + errors.join('\n'));
    renderPreviews();
  }

  fotoInput.addEventListener('change', e => { addFiles(e.target.files); fotoInput.value = ''; });
  uploadArea.addEventListener('dragover',  e => { e.preventDefault(); uploadArea.classList.add('dragover'); });
  uploadArea.addEventListener('dragleave', ()  => uploadArea.classList.remove('dragover'));
  uploadArea.addEventListener('drop', e => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    addFiles(e.dataTransfer.files);
  });

  // ── Keunggulan: tambah baris ──
  function makeRemoveBtn() {
    const btn = document.createElement('button');
    btn.className = 'btn-remove';
    btn.title = 'Hapus';
    btn.textContent = '✕';
    btn.style.cssText = 'flex-shrink:0;width:28px;height:28px;border:1.5px solid var(--border);border-radius:6px;background:var(--paper-2);color:var(--ink-muted);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;';
    btn.addEventListener('click', () => {
      const list = document.getElementById('keung-list');
      if (list.children.length > 1) btn.closest('.keung-row').remove();
    });
    return btn;
  }

  document.getElementById('btn-remove-init').addEventListener('click', function() {
    const list = document.getElementById('keung-list');
    if (list.children.length > 1) this.closest('.keung-row').remove();
  });

  document.getElementById('btn-add-keung').addEventListener('click', () => {
    const list = document.getElementById('keung-list');
    const row = document.createElement('div');
    row.className = 'keung-row';
    row.style.cssText = 'display:flex;gap:6px;align-items:center;';
    const inp = document.createElement('input');
    inp.type = 'text';
    inp.placeholder = 'Keunggulan PKBM...';
    inp.style.cssText = 'flex:1;font-family:inherit;font-size:14px;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;background:var(--paper);color:var(--ink);box-sizing:border-box;outline:none;';
    row.appendChild(inp);
    row.appendChild(makeRemoveBtn());
    list.appendChild(row);
    inp.focus();
  });

  // ── Helpers ──
  function slug(str) {
    return str.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  function getPrograms() {
    const chips = [...document.querySelectorAll('#program-chips .chip.active')].map(c => c.dataset.val);
    const custom = document.getElementById('program-custom').value.split(',').map(s => s.trim()).filter(Boolean);
    return [...chips, ...custom];
  }

  function getKeunggulan() {
    return [...document.querySelectorAll('#keung-list input')].map(i => i.value.trim()).filter(Boolean);
  }

  // Hasilkan placeholder path galeri berdasarkan slug PKBM dan jumlah foto
  function buildGaleriSlugs(pkbmSlug, count) {
    const paths = [];
    for (let i = 1; i <= count; i++) {
      paths.push('/images/pkbm/' + pkbmSlug + '-' + i + '.jpg');
    }
    return paths;
  }

  function buildMd({ nama, tahun, kota, provinsi, status, deskripsi, narasi, website, maps,
                     kontakTelp, kontakEmail, pengisi, programs, keunggulan, pkbmSlug, fotoCount }) {
    const esc      = s => s.replace(/"/g, '\\"');
    const tahunVal = tahun || new Date().getFullYear();

    // program sebagai YAML list
    const progYaml = programs.length
      ? 'program:\n' + programs.map(p => '  - "' + esc(p) + '"').join('\n')
      : 'program: []';

    const keungYaml = keunggulan.length
      ? 'keunggulan:\n' + keunggulan.map(k => '  - "' + esc(k) + '"').join('\n')
      : 'keunggulan: []';

    // image: foto pertama sebagai cover
    const imageVal = fotoCount > 0
      ? '"/images/pkbm/' + pkbmSlug + '.jpg"'
      : '"/images/pkbm/placeholder.jpg"';

    // galeri: placeholder paths (admin yang rename & upload ke repo)
    const galeriSlugs = buildGaleriSlugs(pkbmSlug, fotoCount);
    const galeriYaml = galeriSlugs.length
      ? 'galeri:\n' + galeriSlugs.map(g => '  - "' + g + '"').join('\n')
      : 'galeri: []';

    const websiteVal  = website ? '"' + esc(website) + '"' : '""';
    const pengisiLine = pengisi ? '<!-- Diisi oleh: ' + pengisi + ' -->\n\n' : '';

    const fm = [
      '---',
      'nama: "' + esc(nama) + '"',
      'image: ' + imageVal,
      'kota: "' + esc(kota) + '"',
      'provinsi: "' + esc(provinsi) + '"',
      'status: "' + status + '"',
      'tahunBerdiri: ' + tahunVal,
      progYaml,
      'website: ' + websiteVal,
      'maps: "' + esc(maps||'') + '"',
      'kontak: "' + esc(kontakTelp||'') + '"',
      'email: "' + esc(kontakEmail||'') + '"',
      'deskripsi: "' + esc(deskripsi) + '"',
      keungYaml,
      galeriYaml,
      '---',
    ].join('\n');

    return fm + '\n\n' + pengisiLine + narasi;
  }

  function setLoading(on) {
    document.getElementById('btn-submit').disabled = on;
    document.getElementById('spinner').style.display = on ? 'block' : 'none';
    document.getElementById('btn-label').textContent = on ? 'Mengirim…' : 'Kirim ke admin';
  }

  function showStatus(type, html) {
    const el = document.getElementById('status-banner');
    el.className = 'status-banner ' + type;
    el.innerHTML = html;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function showPreview(md, fileSlug) {
    document.getElementById('output').textContent = md;
    document.getElementById('output-filename').textContent = fileSlug + '.md';
    document.getElementById('output-wrap').style.display = 'block';
  }

  // ── Submit ──
  document.getElementById('btn-submit').addEventListener('click', async () => {
    const nama        = document.getElementById('nama').value.trim();
    const tahun       = document.getElementById('tahun').value.trim();
    const kota        = document.getElementById('kota').value.trim();
    const provinsi    = document.getElementById('provinsi').value.trim();
    const status      = document.getElementById('status').value;
    const deskripsi   = document.getElementById('deskripsi').value.trim();
    const narasi      = document.getElementById('narasi').value.trim();
    const website     = document.getElementById('website').value.trim();
    const pengisi     = document.getElementById('pengisi').value.trim();
    const programs    = getPrograms();
    const keunggulan  = getKeunggulan();
    const maps        = document.getElementById('maps').value.trim();
    const kontakTelp  = document.getElementById('kontak-telp').value.trim();
    const kontakEmail = document.getElementById('kontak-email').value.trim();
    const pkbmSlug    = slug(nama) || 'pkbm-baru';

    const md = buildMd({ nama, tahun, kota, provinsi, status, deskripsi, narasi, website, maps,
                         kontakTelp, kontakEmail, pengisi, programs, keunggulan,
                         pkbmSlug, fotoCount: selectedPhotos.length });

    // Validasi
    const missing = [];
    if (!nama)                 missing.push('Nama PKBM');
    if (!kota)                 missing.push('Kota / Kabupaten');
    if (!provinsi)             missing.push('Provinsi');
    if (!deskripsi)            missing.push('Deskripsi singkat');
    if (!narasi)               missing.push('Narasi / profil lengkap');
    if (programs.length === 0) missing.push('minimal satu program');
    if (missing.length > 0) {
      showStatus('error', '<strong>Mohon lengkapi field berikut:</strong><br>• ' + missing.join('<br>• '));
      return;
    }

    window._mdContent = md;
    window._mdSlug    = pkbmSlug;

    document.getElementById('status-banner').style.display = 'none';
    setLoading(true);

    // ── Kirim ke Apps Script via no-cors (workaround CORS Google Apps Script) ──
    // Apps Script deployed sebagai Web App tidak mengirim CORS header untuk POST JSON,
    // sehingga kita pakai form-encoded agar browser tidak melakukan preflight.
    // Data JSON dikirim sebagai satu field "payload" di dalam form body.
    try {
      const payload = JSON.stringify({
        nama_pkbm   : nama,
        kota        : kota,
        provinsi    : provinsi,
        status      : status,
        pengisi     : pengisi || '(tidak diisi)',
        kontak_telp : kontakTelp,
        kontak_email: kontakEmail,
        filename    : pkbmSlug + '.md',
        md_content  : md,
        photos      : selectedPhotos,  // [{ name, base64, type }]
      });

      // Kirim sebagai application/x-www-form-urlencoded → tidak trigger preflight CORS
      const formBody = 'payload=' + encodeURIComponent(payload);

      await fetch(APPS_SCRIPT_URL, {
        method : 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body   : formBody,
        mode   : 'no-cors',  // Apps Script tidak kirim CORS header → gunakan no-cors
      });

      // no-cors selalu returns opaque response, tidak bisa cek status → anggap sukses
      showStatus('success',
        '<strong>✓ Terima kasih' + (pengisi ? ', ' + pengisi : '') + '!</strong><br>' +
        'Profil <em>' + nama + '</em> sudah dikirim ke admin dan akan segera ditinjau.' +
        (selectedPhotos.length > 0 ? '<br>📷 ' + selectedPhotos.length + ' foto berhasil dikirim.' : '') +
        '<br>Kamu juga bisa unduh file .md-nya di bawah sebagai arsip.'
      );
      showPreview(md, pkbmSlug);

    } catch (err) {
      console.error('Apps Script error:', err);
      showStatus('error',
        '<strong>Gagal mengirim.</strong> Silakan coba lagi.<br>' +
        '<small style="opacity:.65">Error: ' + (err && err.message ? err.message : String(err)) + '</small><br><br>' +
        'Alternatif: unduh file .md di bawah dan kirim manual ke admin.'
      );
      showPreview(md, pkbmSlug);
    } finally {
      setLoading(false);
    }
  });

  // ── Copy ──
  document.getElementById('btn-copy').addEventListener('click', () => {
    if (!window._mdContent) return;
    navigator.clipboard.writeText(window._mdContent).then(() => {
      const toast = document.getElementById('copy-toast');
      toast.textContent = '✓ Tersalin! Simpan sebagai: ' + (window._mdSlug || 'pkbm') + '.md';
      setTimeout(() => { toast.textContent = ''; }, 3000);
    });
  });

  // ── Download ──
  document.getElementById('btn-dl').addEventListener('click', () => {
    if (!window._mdContent) return;
    const blob = new Blob([window._mdContent], { type: 'text/markdown;charset=utf-8' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = (window._mdSlug || 'pkbm') + '.md';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  });

}); // end DOMContentLoaded
</script>

</BaseLayout>