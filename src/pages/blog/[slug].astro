---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <article class="post-container">
    <div class="post-hero">
      <div class="container">
        <div class="post-meta">
          <a href="/blog" class="back-link">← Kembali ke Blog</a>
          <span class="post-date">
            {post.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
          </span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-tags">
          {post.data.tags.map(t => <span class="tag">{t}</span>)}
        </div>
        <div class="post-author">✍️ {post.data.author}</div>
      </div>
    </div>

    <div class="container">
      <div class="post-body prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-hero {
    background: var(--clr-primary-light);
    border-bottom: 1px solid var(--clr-border);
    padding: 2.5rem 0;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--clr-text-muted);
  }

  .back-link {
    color: var(--clr-primary);
    font-weight: 600;
    font-size: 0.88rem;
    transition: opacity 0.15s;
  }
  .back-link:hover { opacity: 0.7; }

  .post-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin-bottom: 0.75rem;
  }

  .post-desc {
    color: var(--clr-text-muted);
    font-size: 1rem;
    margin-bottom: 1rem;
    max-width: 640px;
  }

  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }

  .post-author {
    font-size: 0.85rem;
    color: var(--clr-text-muted);
  }

  .post-body {
    max-width: 720px;
    margin: 3rem auto;
    padding-bottom: 4rem;
  }

  /* Prose styles */
  .prose :global(h2) { font-size: 1.5rem; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.2rem; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1.2rem; color: var(--clr-text); line-height: 1.8; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.2rem; }
  .prose :global(li) { margin-bottom: 0.4rem; line-height: 1.7; }
  .prose :global(blockquote) {
    border-left: 4px solid var(--clr-primary);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--clr-primary-light);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--clr-text-muted);
  }
  .prose :global(code) {
    background: var(--clr-primary-light);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.88em;
  }
  .prose :global(a) { color: var(--clr-primary); text-decoration: underline; }
  .prose :global(strong) { color: var(--clr-text); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--clr-border); margin: 2rem 0; }
</style>
