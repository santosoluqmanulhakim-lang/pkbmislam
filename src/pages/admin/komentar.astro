---
const adminUid = import.meta.env.PUBLIC_ADMIN_UID ?? "";
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Moderasi Komentar — Admin PKBM Islam</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f4f0;
      --surface: #ffffff;
      --surface2: #f0efe9;
      --border: #e2e0d8;
      --text: #1a1916;
      --muted: #7a7870;
      --accent: #1d6a4a;
      --accent-light: #e6f2ec;
      --danger: #c0392b;
      --danger-light: #fdf0ee;
      --radius: 8px;
      --radius-lg: 12px;
    }

    body { font-family: 'Georgia', serif; background: var(--bg); color: var(--text); min-height: 100vh; }

    .header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .header-brand { display: flex; align-items: center; gap: 10px; font-size: 15px; font-weight: 600; color: var(--text); }
    .header-brand span { font-size: 11px; font-weight: 400; color: var(--muted); background: var(--surface2); padding: 2px 8px; border-radius: 99px; border: 1px solid var(--border); font-family: 'Courier New', monospace; }
    .header-user { display: flex; align-items: center; gap: 10px; }
    #admin-photo { width: 30px; height: 30px; border-radius: 50%; display: none; border: 1.5px solid var(--border); }
    #admin-name { font-size: 13px; color: var(--muted); font-family: sans-serif; }
    #logout-btn { font-size: 12px; padding: 4px 12px; border: 1px solid var(--border); border-radius: 99px; background: none; cursor: pointer; color: var(--muted); font-family: sans-serif; display: none; transition: all 0.15s; }
    #logout-btn:hover { background: var(--surface2); color: var(--text); }

    #login-gate { display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 56px); }
    .login-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem 2rem; text-align: center; max-width: 360px; width: 100%; }
    .login-card h2 { font-size: 18px; margin-bottom: 6px; }
    .login-card p { font-size: 13px; color: var(--muted); margin-bottom: 1.5rem; font-family: sans-serif; line-height: 1.6; }
    .google-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 10px 20px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); cursor: pointer; font-size: 14px; font-family: sans-serif; color: var(--text); width: 100%; transition: background 0.15s; }
    .google-btn:hover { background: var(--surface2); }
    #not-admin-msg { display: none; background: var(--danger-light); color: var(--danger); font-size: 13px; padding: 10px 14px; border-radius: var(--radius); margin-top: 12px; font-family: sans-serif; line-height: 1.5; }

    #admin-panel { display: none; }
    .container { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }

    .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 2rem; }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; }
    .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; font-family: 'Courier New', monospace; margin-bottom: 4px; }
    .stat-value { font-size: 26px; font-weight: 600; }
    .stat-value.danger { color: var(--danger); }

    .filter-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .filter-bar input { flex: 1; min-width: 180px; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; background: var(--surface); font-family: sans-serif; color: var(--text); outline: none; }
    .filter-bar input:focus { border-color: var(--accent); }
    .filter-bar select { padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; background: var(--surface); color: var(--text); font-family: sans-serif; cursor: pointer; }
    .btn-refresh { padding: 8px 14px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); font-size: 13px; cursor: pointer; color: var(--muted); font-family: sans-serif; white-space: nowrap; transition: all 0.15s; }
    .btn-refresh:hover { background: var(--surface2); color: var(--text); }

    #comments-container { display: flex; flex-direction: column; gap: 10px; }
    .comment-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.25rem; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: start; animation: fadeIn 0.2s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
    .comment-card.flagged { border-color: #f5c6c2; background: #fffaf9; }
    .comment-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
    .comment-avatar { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--border); flex-shrink: 0; }
    .comment-name { font-size: 13px; font-weight: 600; font-family: sans-serif; }
    .comment-slug { font-size: 11px; color: var(--accent); background: var(--accent-light); padding: 2px 8px; border-radius: 99px; font-family: 'Courier New', monospace; text-decoration: none; }
    .comment-date { font-size: 11px; color: var(--muted); font-family: sans-serif; }
    .comment-text { font-size: 14px; line-height: 1.65; margin-bottom: 4px; }
    .comment-uid { font-size: 10px; color: var(--muted); font-family: 'Courier New', monospace; }
    .btn-delete { padding: 6px 14px; font-size: 12px; border: 1px solid #f5c6c2; border-radius: var(--radius); background: var(--danger-light); color: var(--danger); cursor: pointer; font-family: sans-serif; white-space: nowrap; transition: all 0.15s; }
    .btn-delete:hover { background: var(--danger); color: white; border-color: var(--danger); }
    .btn-delete:disabled { opacity: 0.4; cursor: not-allowed; }
    .state-msg { text-align: center; padding: 3rem; color: var(--muted); font-family: sans-serif; font-size: 14px; }

    #toast { position: fixed; bottom: 24px; right: 24px; background: var(--text); color: white; font-size: 13px; font-family: sans-serif; padding: 10px 18px; border-radius: var(--radius); opacity: 0; transform: translateY(8px); transition: all 0.2s; pointer-events: none; z-index: 100; }
    #toast.show { opacity: 1; transform: translateY(0); }
    #toast.danger { background: var(--danger); }
  </style>
</head>
<body>

<!-- Penampung UID admin dari environment variable -->
<div id="admin-config" data-uid={adminUid} style="display:none;"></div>

<header class="header">
  <div class="header-brand">
    pkbmislam.id <span>admin / komentar</span>
  </div>
  <div class="header-user">
    <img id="admin-photo" src="" alt="foto admin" referrerpolicy="no-referrer" />
    <span id="admin-name"></span>
    <button id="logout-btn">Keluar</button>
  </div>
</header>

<div id="login-gate">
  <div class="login-card">
    <h2>Moderasi Komentar</h2>
    <p>Halaman ini hanya untuk administrator.<br>Masuk dengan akun Google yang terdaftar.</p>
    <button class="google-btn" id="login-btn">
      <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="18" alt="Google" />
      Masuk dengan Google
    </button>
    <div id="not-admin-msg">Akun ini tidak memiliki akses admin.<br>Hubungi pengelola sistem.</div>
  </div>
</div>

<div id="admin-panel">
  <div class="container">
    <div class="stats-row">
      <div class="stat-card"><div class="stat-label">Total Komentar</div><div class="stat-value" id="stat-total">—</div></div>
      <div class="stat-card"><div class="stat-label">Hari Ini</div><div class="stat-value" id="stat-today">—</div></div>
      <div class="stat-card"><div class="stat-label">Unik Pengguna</div><div class="stat-value" id="stat-users">—</div></div>
      <div class="stat-card"><div class="stat-label">Perlu Tinjauan</div><div class="stat-value danger" id="stat-flagged">—</div></div>
    </div>
    <div class="filter-bar">
      <input type="search" id="search-input" placeholder="Cari nama, teks, atau slug..." />
      <select id="filter-slug"><option value="">Semua halaman</option></select>
      <button class="btn-refresh" id="refresh-btn">↺ Muat ulang</button>
    </div>
    <div id="comments-container"><div class="state-msg">Memuat komentar...</div></div>
  </div>
</div>

<div id="toast"></div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-app.js";
  import { getAuth, GoogleAuthProvider, signInWithPopup, signOut, onAuthStateChanged }
    from "https://www.gstatic.com/firebasejs/12.13.0/firebase-auth.js";
  import { getFirestore, collection, getDocs, deleteDoc, doc, orderBy, query }
    from "https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyAJfV1PjIGOAAMsaINMAlU30Oy-ji6hJlo",
    authDomain: "pkbmislam-comment.firebaseapp.com",
    projectId: "pkbmislam-comment",
    storageBucket: "pkbmislam-comment.firebasestorage.app",
    messagingSenderId: "692599447287",
    appId: "1:692599447287:web:3ba568cf53eb952fbdfdf2",
  };

  // UID dibaca dari frontmatter via data attribute — tidak hardcode di sini
  const ADMIN_UIDS = [document.getElementById("admin-config").dataset.uid].filter(Boolean);

  const FLAG_WORDS = ["spam", "judi", "porno", "babi", "anjing", "bangsat"];

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);
  let allComments = [];

  document.getElementById("login-btn").addEventListener("click", () =>
    signInWithPopup(auth, new GoogleAuthProvider()).catch(e => showToast(e.message, true)));
  document.getElementById("logout-btn").addEventListener("click", () => signOut(auth));

  onAuthStateChanged(auth, async user => {
    if (user) {
      if (!ADMIN_UIDS.includes(user.uid)) {
        document.getElementById("not-admin-msg").style.display = "block";
        await signOut(auth);
        return;
      }
      document.getElementById("login-gate").style.display = "none";
      document.getElementById("admin-panel").style.display = "block";
      document.getElementById("admin-name").textContent = user.displayName;
      const photo = document.getElementById("admin-photo");
      photo.src = user.photoURL || ""; photo.style.display = "block";
      document.getElementById("logout-btn").style.display = "inline-block";
      loadComments();
    } else {
      document.getElementById("login-gate").style.display = "flex";
      document.getElementById("admin-panel").style.display = "none";
      document.getElementById("logout-btn").style.display = "none";
      document.getElementById("admin-photo").style.display = "none";
      document.getElementById("admin-name").textContent = "";
    }
  });

  async function loadComments() {
    document.getElementById("comments-container").innerHTML = '<div class="state-msg">Memuat komentar...</div>';
    try {
      const snap = await getDocs(query(collection(db, "comments"), orderBy("createdAt", "desc")));
      allComments = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      updateStats(); populateSlugFilter(); renderComments();
    } catch (e) {
      document.getElementById("comments-container").innerHTML =
        `<div class="state-msg">Gagal memuat: ${e.message}</div>`;
    }
  }

  document.getElementById("refresh-btn").addEventListener("click", loadComments);

  function updateStats() {
    const today = new Date().toDateString();
    document.getElementById("stat-total").textContent = allComments.length;
    document.getElementById("stat-today").textContent =
      allComments.filter(c => c.createdAt?.toDate?.().toDateString() === today).length;
    document.getElementById("stat-users").textContent =
      new Set(allComments.map(c => c.uid)).size;
    document.getElementById("stat-flagged").textContent =
      allComments.filter(c => isFlagged(c.text)).length;
  }

  function isFlagged(text = "") { return FLAG_WORDS.some(w => text.toLowerCase().includes(w)); }

  function populateSlugFilter() {
    const slugs = [...new Set(allComments.map(c => c.slug).filter(Boolean))].sort();
    const sel = document.getElementById("filter-slug");
    sel.innerHTML = '<option value="">Semua halaman</option>';
    slugs.forEach(s => { const o = document.createElement("option"); o.value = s; o.textContent = s; sel.appendChild(o); });
  }

  function getFiltered() {
    const q = document.getElementById("search-input").value.toLowerCase().trim();
    const slug = document.getElementById("filter-slug").value;
    return allComments.filter(c =>
      (!slug || c.slug === slug) &&
      (!q || [c.displayName, c.text, c.slug].some(v => v?.toLowerCase().includes(q)))
    );
  }

  function renderComments() {
    const filtered = getFiltered();
    const container = document.getElementById("comments-container");
    if (!filtered.length) { container.innerHTML = '<div class="state-msg">Tidak ada komentar ditemukan.</div>'; return; }
    container.innerHTML = filtered.map(c => {
      const flagged = isFlagged(c.text);
      const waktu = c.createdAt?.toDate
        ? c.createdAt.toDate().toLocaleString("id-ID", { day:"numeric", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" })
        : "—";
      return `
        <div class="comment-card ${flagged ? 'flagged' : ''}" data-id="${c.id}">
          <div>
            <div class="comment-meta">
              <img class="comment-avatar" src="${c.photoURL||''}" referrerpolicy="no-referrer" onerror="this.style.display='none'" alt="" />
              <span class="comment-name">${esc(c.displayName||'Anonim')}</span>
              ${c.slug ? `<a class="comment-slug" href="/blog/${esc(c.slug)}" target="_blank">${esc(c.slug)}</a>` : ''}
              <span class="comment-date">${waktu}</span>
              ${flagged ? '<span style="font-size:11px;color:#c0392b;font-family:sans-serif;">⚑ Perlu tinjauan</span>' : ''}
            </div>
            <p class="comment-text">${esc(c.text||'')}</p>
            <div class="comment-uid">uid: ${c.uid||'—'}</div>
          </div>
          <div><button class="btn-delete" onclick="hapusKomentar('${c.id}',this)">Hapus</button></div>
        </div>`;
    }).join("");
  }

  document.getElementById("search-input").addEventListener("input", renderComments);
  document.getElementById("filter-slug").addEventListener("change", renderComments);

  window.hapusKomentar = async (id, btn) => {
    if (!confirm("Hapus komentar ini? Tindakan tidak bisa dibatalkan.")) return;
    btn.disabled = true; btn.textContent = "Menghapus...";
    try {
      await deleteDoc(doc(db, "comments", id));
      const card = document.querySelector(`[data-id="${id}"]`);
      if (card) { card.style.opacity = "0"; card.style.transition = "opacity 0.2s"; }
      setTimeout(() => { allComments = allComments.filter(c => c.id !== id); updateStats(); renderComments(); }, 200);
      showToast("Komentar berhasil dihapus.");
    } catch (e) {
      btn.disabled = false; btn.textContent = "Hapus";
      showToast("Gagal menghapus: " + e.message, true);
    }
  };

  function showToast(msg, isDanger = false) {
    const t = document.getElementById("toast");
    t.textContent = msg; t.className = "show" + (isDanger ? " danger" : "");
    setTimeout(() => t.className = "", 3000);
  }

  function esc(str) {
    return String(str).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
  }
</script>
</body>
</html>