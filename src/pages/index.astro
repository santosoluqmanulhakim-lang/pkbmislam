---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const pkbmList = (await getCollection('pkbm-profil')).slice(0, 6);
---

<BaseLayout title="Beranda" description="Portal informasi lengkap seputar PKBM Islam di Indonesia — panduan pendirian, program kesetaraan Paket A B C, dan profil lembaga.">

  <!-- Hero Slideshow -->
  <section class="hero">
    <div class="slides">
      <div class="slide active" style="background-image: url('/images/slides/slide-1.jpg')">
        <div class="slide-overlay"></div>
        <div class="slide-content container">
          <div class="hero-badge">Pendidikan Non-Formal Islami</div>
          <h1>Informasi Lengkap<br/><em>Seputar PKBM</em></h1>
          <p class="hero-desc">Panduan mendirikan PKBM, mengenal program kesetaraan Paket A, B, C, serta profil PKBM Islam yang telah berkiprah di berbagai daerah.</p>
          <div class="hero-actions">
            <a href="/pendirian" class="btn btn-primary">Cara Mendirikan PKBM →</a>
            <a href="/program" class="btn btn-outline">Lihat Program</a>
          </div>
        </div>
      </div>
      <div class="slide" style="background-image: url('/images/slides/slide-2.jpg')">
        <div class="slide-overlay"></div>
        <div class="slide-content container">
          <div class="hero-badge">Program Kesetaraan</div>
          <h1>Paket A, B & C<br/><em>Diakui Negara</em></h1>
          <p class="hero-desc">Ijazah kesetaraan setara SD, SMP, dan SMA — terbuka untuk semua usia, fleksibel, dan bernilai Islam.</p>
          <div class="hero-actions">
            <a href="/program" class="btn btn-primary">Lihat Program →</a>
            <a href="/faq" class="btn btn-outline">FAQ</a>
          </div>
        </div>
      </div>
      <div class="slide" style="background-image: url('/images/slides/slide-3.jpg')">
        <div class="slide-overlay"></div>
        <div class="slide-content container">
          <div class="hero-badge">Profil PKBM Islam</div>
          <h1>Belajar dari<br/><em>Yang Sudah Berjalan</em></h1>
          <p class="hero-desc">Kenali PKBM Islam yang telah sukses beroperasi — cerita, tantangan, dan keunggulan mereka.</p>
          <div class="hero-actions">
            <a href="/profil-pkbm" class="btn btn-primary">Lihat Profil PKBM →</a>
            <a href="/blog" class="btn btn-outline">Baca Artikel</a>
          </div>
        </div>
      </div>
    </div>
    <div class="slide-dots">
      <button class="dot active" data-slide="0"></button>
      <button class="dot" data-slide="1"></button>
      <button class="dot" data-slide="2"></button>
    </div>
  </section>

  <!-- Program Unggulan -->
  <section class="programs">
    <div class="container">
      <h2 class="section-title">Program PKBM</h2>
      <p class="section-subtitle">Tiga jalur pendidikan kesetaraan yang diakui negara</p>
      <div class="program-grid">
        <a href="/program#paket-a" class="program-card">
          <div class="program-thumb">
            <img src="/images/program/paket-a.jpg" alt="Paket A" loading="lazy" onerror="this.parentElement.classList.add('no-img')" />
            <div class="program-thumb-label">Paket A</div>
          </div>
          <div class="program-body">
            <h3>Paket A — Setara SD</h3>
            <p>Untuk peserta didik yang belum menyelesaikan pendidikan dasar 6 tahun.</p>
            <span class="program-link">Selengkapnya →</span>
          </div>
        </a>
        <a href="/program#paket-b" class="program-card">
          <div class="program-thumb">
            <img src="/images/program/paket-b.jpg" alt="Paket B" loading="lazy" onerror="this.parentElement.classList.add('no-img')" />
            <div class="program-thumb-label">Paket B</div>
          </div>
          <div class="program-body">
            <h3>Paket B — Setara SMP</h3>
            <p>Membuka akses pendidikan menengah pertama bagi masyarakat putus sekolah.</p>
            <span class="program-link">Selengkapnya →</span>
          </div>
        </a>
        <a href="/program#paket-c" class="program-card">
          <div class="program-thumb">
            <img src="/images/program/paket-c.jpg" alt="Paket C" loading="lazy" onerror="this.parentElement.classList.add('no-img')" />
            <div class="program-thumb-label">Paket C</div>
          </div>
          <div class="program-body">
            <h3>Paket C — Setara SMA</h3>
            <p>Ijazah diakui untuk melanjutkan ke perguruan tinggi atau melamar kerja.</p>
            <span class="program-link">Selengkapnya →</span>
          </div>
        </a>
        <a href="/program#keterampilan" class="program-card program-card--accent">
          <div class="program-thumb">
            <img src="/images/program/keterampilan.jpg" alt="Keterampilan" loading="lazy" onerror="this.parentElement.classList.add('no-img')" />
            <div class="program-thumb-label">Life Skills</div>
          </div>
          <div class="program-body">
            <h3>Keterampilan & Life Skills</h3>
            <p>Program vokasional: menjahit, komputer, wirausaha, pertanian, dan lainnya.</p>
            <span class="program-link">Selengkapnya →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Pendirian Cepat -->
  <section class="pendirian-cta">
    <div class="container">
      <div class="pendirian-box">
        <div class="pendirian-text">
          <h2>Ingin Mendirikan PKBM?</h2>
          <p>Kami rangkum panduan lengkap: syarat, dokumen, alur izin operasional, hingga tips membangun PKBM yang berlandaskan nilai Islam.</p>
          <a href="/pendirian" class="btn btn-primary">Baca Panduan Pendirian →</a>
        </div>
        <div class="pendirian-steps">
          <div class="step"><span>1</span> Bentuk Yayasan / Lembaga</div>
          <div class="step"><span>2</span> Siapkan Dokumen Legalitas</div>
          <div class="step"><span>3</span> Daftarkan ke Dinas Pendidikan</div>
          <div class="step"><span>4</span> Masuk Data Dapodik & NISN</div>
          <div class="step"><span>5</span> Mulai Operasional</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Profil PKBM -->
  {pkbmList.length > 0 && (
    <section class="profil-section">
      <div class="container">
        <h2 class="section-title">Profil PKBM Islam</h2>
        <p class="section-subtitle">Lembaga-lembaga yang telah berhasil menjalankan PKBM berbasis nilai Islam</p>
        <div class="pkbm-grid">
          {pkbmList.map(pkbm => (
            <a href={`/profil-pkbm/${pkbm.slug}`} class="pkbm-card">
              <div class="pkbm-thumb">
                {pkbm.data.image
                  ? <img src={pkbm.data.image} alt={pkbm.data.nama} loading="lazy" decoding="async" />
                  : <div class="pkbm-thumb-placeholder">{pkbm.data.kota}</div>
                }
              </div>
              <div class="pkbm-body">
                <h3>{pkbm.data.nama}</h3>
                <div class="pkbm-programs">
                  {pkbm.data.program.slice(0,3).map(p => <span class="tag">{p}</span>)}
                </div>
              </div>
            </a>
          ))}
        </div>
        <div style="text-align:center; margin-top:2rem;">
          <a href="/profil-pkbm" class="btn btn-outline">Lihat Semua Profil →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Blog Terbaru -->
  {posts.length > 0 && (
    <section class="blog-section">
      <div class="container">
        <h2 class="section-title">Artikel Terbaru</h2>
        <p class="section-subtitle">Wawasan, panduan, dan inspirasi seputar pendidikan non-formal</p>
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-thumb">
                {post.data.image
                  ? <img src={post.data.image} alt={post.data.title} loading="lazy" />
                  : <div class="blog-thumb-placeholder">{post.data.tags[0] ?? 'PKBM'}</div>
                }
              </div>
              <div class="blog-body">
                <h3>{post.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
        <div style="text-align:center; margin-top:2rem;">
          <a href="/blog" class="btn btn-outline">Semua Artikel →</a>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Cuplikan -->
  <section class="faq-preview">
    <div class="container">
      <div class="faq-box">
        <h2>Pertanyaan Umum</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Apakah ijazah PKBM diakui secara nasional?</summary>
            <p>Ya. Ijazah Paket A, B, dan C setara dengan ijazah SD, SMP, dan SMA. Diakui oleh Kemendikdasmen dan dapat digunakan untuk melanjutkan pendidikan atau melamar pekerjaan.</p>
          </details>
          <details class="faq-item">
            <summary>Berapa biaya mendirikan PKBM?</summary>
            <p>Biaya bervariasi tergantung daerah. Umumnya meliputi biaya pengurusan akta yayasan, legalisir dokumen, dan operasional awal. Tidak ada biaya khusus yang ditetapkan pemerintah untuk pendaftaran PKBM.</p>
          </details>
          <details class="faq-item">
            <summary>Apakah PKBM bisa mendapat bantuan dari pemerintah?</summary>
            <p>Ya, PKBM yang sudah terdaftar di Dapodik berhak mengajukan berbagai bantuan dari Kemendikdasmen maupun pemerintah daerah, seperti BOP (Biaya Operasional Pendidikan).</p>
          </details>
        </div>
        <a href="/faq" class="btn btn-outline" style="margin-top:1.5rem;">Lihat Semua FAQ →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function() {
  const slides = document.querySelectorAll('.slide');
  const dots   = document.querySelectorAll('.dot');
  let current  = 0;
  let timer;

  function goTo(n) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  function startTimer() { timer = setInterval(() => goTo(current + 1), 2000); }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(parseInt(dot.dataset.slide));
      startTimer();
    });
  });

  const hero = document.querySelector('.hero');

  startTimer();
})();
</script>

<style>
  /* ── Hero Slideshow ── */
  .hero { position: relative; overflow: hidden; height: 520px; }
  @media (max-width: 768px) { .hero { height: 460px; } }

  .slides { width: 100%; height: 100%; position: relative; }

  .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: var(--clr-primary-dark);
    opacity: 0;
    transition: opacity 0.8s ease;
    display: flex;
    align-items: center;
  }
  .slide.active { opacity: 1; }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(17,77,41,0.88) 0%, rgba(26,107,58,0.65) 60%, rgba(26,107,58,0.25) 100%);
  }

  .slide-content {
    position: relative;
    z-index: 1;
    color: #fff;
    max-width: 620px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.35rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    margin-bottom: 1.2rem;
    backdrop-filter: blur(4px);
  }

  .slide-content h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .slide-content h1 em { color: var(--clr-accent); font-style: italic; }

  .hero-desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.88);
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .hero-actions .btn-outline { border-color: rgba(255,255,255,0.6); color: #fff; }
  .hero-actions .btn-outline:hover { background: rgba(255,255,255,0.15); }

  .slide-dots {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.4);
    cursor: pointer;
    padding: 0;
    transition: all 0.3s;
  }
  .dot.active { background: #fff; width: 24px; border-radius: 4px; }

  @media (max-width: 768px) {
    .slide-content { padding: 0 1.25rem; }
    .hero-desc { font-size: 0.92rem; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }

  /* ── Programs ── */
  .program-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .program-card {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .program-card:hover { border-color: var(--clr-primary); box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .program-card--accent { border-left: 4px solid var(--clr-accent); }

  .program-thumb {
    width: 100%;
    height: 150px;
    overflow: hidden;
    position: relative;
    background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));
    flex-shrink: 0;
  }
  .program-thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .program-card:hover .program-thumb img { transform: scale(1.05); }
  .program-thumb.no-img img { display: none; }
  .program-thumb-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  /* label hanya tampil jika gambar gagal load */
  .program-thumb:not(.no-img) .program-thumb-label { display: none; }

  .program-body { padding: 1.25rem 1.5rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .program-body h3 { font-size: 1rem; }
  .program-body p { font-size: 0.88rem; color: var(--clr-text-muted); flex: 1; }
  .program-link { font-size: 0.85rem; font-weight: 600; color: var(--clr-primary); margin-top: 0.25rem; }

  /* ── Pendirian CTA ── */
  .pendirian-box {
    background: var(--clr-primary-light);
    border: 1px solid rgba(26,107,58,0.2);
    border-radius: 16px;
    padding: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .pendirian-text h2 { margin-bottom: 0.75rem; }
  .pendirian-text p { color: var(--clr-text-muted); margin-bottom: 1.25rem; font-size: 0.95rem; }
  .pendirian-steps { display: flex; flex-direction: column; gap: 0.6rem; }
  .step { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; font-weight: 500; }
  .step span {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--clr-primary); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; font-weight: 700; flex-shrink: 0;
  }
  @media (max-width: 640px) { .pendirian-box { grid-template-columns: 1fr; } }

  /* ── PKBM Grid ── */
  .pkbm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .pkbm-card {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .pkbm-card:hover { border-color: var(--clr-primary); box-shadow: var(--shadow-md); transform: translateY(-3px); }

  .pkbm-thumb {
    width: 100%; height: 160px;
    overflow: hidden; flex-shrink: 0;
  }
  .pkbm-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .pkbm-card:hover .pkbm-thumb img { transform: scale(1.05); }
  .pkbm-thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));
    color: rgba(255,255,255,0.6);
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .pkbm-body { padding: 1rem 1.25rem 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .pkbm-body h3 { font-size: 1rem; }
  .pkbm-programs { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  /* ── Blog ── */
  .blog-section { background: var(--clr-primary-light); }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .blog-card {
    background: var(--clr-surface);
    border-radius: var(--radius);
    border: 1px solid var(--clr-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .blog-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

  .blog-thumb {
    width: 100%; height: 160px;
    overflow: hidden; flex-shrink: 0;
  }
  .blog-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .blog-card:hover .blog-thumb img { transform: scale(1.05); }
  .blog-thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--clr-primary-light), var(--clr-primary));
    color: rgba(255,255,255,0.7);
    font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .blog-body { padding: 1rem 1.25rem 1.25rem; }
  .blog-body h3 { font-size: 0.98rem; line-height: 1.45; color: var(--clr-text); }

  /* ── FAQ ── */
  .faq-box { max-width: 720px; margin: 0 auto; text-align: center; }
  .faq-box h2 { margin-bottom: 1.5rem; }
  .faq-list { text-align: left; display: flex; flex-direction: column; gap: 0.75rem; }
  .faq-item { background: var(--clr-surface); border: 1px solid var(--clr-border); border-radius: var(--radius); overflow: hidden; }
  .faq-item summary {
    padding: 1rem 1.25rem; font-weight: 600; cursor: pointer;
    list-style: none; display: flex; justify-content: space-between;
    align-items: center; font-size: 0.95rem;
  }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--clr-primary); }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: 0.75rem 1.25rem 1rem; font-size: 0.9rem; color: var(--clr-text-muted); border-top: 1px solid var(--clr-border); }
.programs,
.pendirian-cta,
.profil-section,
.blog-section,
.faq-preview { padding: 2.5rem 0; }

</style>
