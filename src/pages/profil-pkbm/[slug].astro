---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const pkbmList = await getCollection('pkbm-profil');
  return pkbmList.map(pkbm => ({
    params: { slug: pkbm.slug },
    props: { pkbm },
  }));
}

const { pkbm } = Astro.props;
const { Content } = await pkbm.render();

const statusClass: Record<string, string> = {
  'PKBM Mandiri - Akreditasi A': 'status-akreditasi-a',
  'PKBM Mandiri - Akreditasi B': 'status-akreditasi-b',
  'PKBM Mandiri - Akreditasi C': 'status-akreditasi-c',
  'PKBM Mandiri - Belum Akreditasi': 'status-belum-akreditasi',
  'Menginduk': 'status-menginduk',
  'Homeschooling': 'status-homeschooling',
};
---

<BaseLayout
  title={pkbm.data.nama}
  description={pkbm.data.deskripsi}
  image={pkbm.data.image}
>
  <div class="page-hero">
    <div class="container">
      <a href="/profil-pkbm" class="back-link">← Semua Profil PKBM</a>
      <h1>{pkbm.data.nama}</h1>
      <div class="meta-row">
        <span>📍 {pkbm.data.kota}, {pkbm.data.provinsi}</span>
        <span>📅 Berdiri {pkbm.data.tahunBerdiri}</span>
      </div>
    </div>
  </div>

  {pkbm.data.image && (
    <div class="pkbm-hero-img">
      <img src={pkbm.data.image} alt={pkbm.data.nama} loading="lazy" decoding="async" />
    </div>
  )}

  <section>
    <div class="container profile-layout">
      <div class="profile-main">
        <div class="prose">
          <Content />
        </div>

        {pkbm.data.galeri && pkbm.data.galeri.length > 0 && (
          <div class="galeri-section">
            <h3 class="galeri-title">Galeri Foto</h3>
            <div class="galeri-slideshow">
              <div class="galeri-track" id="galeri-track">
                {pkbm.data.galeri.map((img, i) => (
                  <div class={`galeri-slide ${i === 0 ? 'active' : ''}`}>
                    <img src={img} alt={`${pkbm.data.nama} foto ${i + 1}`} loading="lazy" decoding="async" />
                  </div>
                ))}
              </div>
              {pkbm.data.galeri.length > 1 && (
                <div class="galeri-controls">
                  <button class="galeri-btn" id="galeri-prev">‹</button>
                  <div class="galeri-dots" id="galeri-dots">
                    {pkbm.data.galeri.map((_, i) => (
                      <button class={`galeri-dot ${i === 0 ? 'active' : ''}`} data-index={i}></button>
                    ))}
                  </div>
                  <button class="galeri-btn" id="galeri-next">›</button>
                </div>
              )}
            </div>
          </div>
        )}
      </div>

      <aside class="profile-sidebar">
        <div class="sidebar-card">
          <h3>Status Legalitas</h3>
          <span class={`status-badge ${statusClass[pkbm.data.status]}`}>
            {pkbm.data.status}
          </span>
        </div>

        <div class="sidebar-card">
          <h3>Program</h3>
          <ul>
            {pkbm.data.program.map(p => <li><span class="tag">{p}</span></li>)}
          </ul>
        </div>

        {pkbm.data.keunggulan.length > 0 && (
          <div class="sidebar-card">
            <h3>Keunggulan</h3>
            <ul class="keunggulan-list">
              {pkbm.data.keunggulan.map(k => <li>✅ {k}</li>)}
            </ul>
          </div>
        )}
        {pkbm.data.kontak && (
          <div class="sidebar-card">
            <h3>Kontak</h3>
            <p>📞 {pkbm.data.kontak}</p>
            {pkbm.data.email && <p>✉️ {pkbm.data.email}</p>}
          </div>
        )}
        {pkbm.data.maps && (
          <div class="sidebar-card">
            <h3>Lokasi</h3>
            <a href={pkbm.data.maps} target="_blank" rel="noopener" class="website-link">
              📍 Lihat di Google Maps
            </a>
          </div>
        )}
        {pkbm.data.website && (
          <div class="sidebar-card">
            <h3>Website / Medsos</h3>
            <a href={pkbm.data.website} target="_blank" rel="noopener" class="website-link">
              🔗 {pkbm.data.website}
            </a>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function() {
  const slides = document.querySelectorAll('.galeri-slide');
  const dots   = document.querySelectorAll('.galeri-dot');
  if (!slides.length || slides.length < 2) return;
  let current = 0;
  function goTo(n) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }
  document.getElementById('galeri-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('galeri-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => {
    dot.addEventListener('click', () => goTo(parseInt(dot.dataset.index)));
  });
})();
</script>

<style>
  .page-hero {
    background: var(--clr-primary);
    color: #fff;
    padding: 2.5rem 0;
  }
  .back-link { color: rgba(255,255,255,0.75); font-size: 0.85rem; display: block; margin-bottom: 0.75rem; transition: color 0.15s; }
  .back-link:hover { color: #fff; }
  .page-hero h1 { color: #fff; font-size: clamp(1.6rem, 3.5vw, 2.4rem); margin-bottom: 0.5rem; }
  .meta-row { display: flex; gap: 1.5rem; color: rgba(255,255,255,0.75); font-size: 0.88rem; flex-wrap: wrap; }

  .pkbm-hero-img { width: 100%; overflow: hidden; }
  .pkbm-hero-img img { width: 100%; height: 420px; object-fit: cover; display: block; }

  .profile-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .profile-layout { grid-template-columns: 1fr; }
    .profile-sidebar { order: -1; }
    .pkbm-hero-img img { height: 220px; }
  }

  /* Prose */
  .prose :global(h2) { font-size: 1.4rem; margin: 2rem 0 0.6rem; }
  .prose :global(p) { margin-bottom: 1.1rem; line-height: 1.8; color: var(--clr-text); }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.4rem; margin-bottom: 1rem; }
  .prose :global(li) { margin-bottom: 0.35rem; line-height: 1.7; }
  .prose :global(blockquote) {
    border-left: 4px solid var(--clr-accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--clr-accent-light);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--clr-text-muted);
  }

  /* Status badge */
  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 600;
  }
  .status-akreditasi-a { background: #d4edda; color: #155724; }
  .status-akreditasi-b { background: #fff3cd; color: #856404; }
  .status-akreditasi-c { background: #f8d7da; color: #721c24; }
  .status-belum-akreditasi { background: #e2e3e5; color: #383d41; }
  .status-menginduk { background: var(--clr-accent-light); color: #7a5c00; }
  .status-homeschooling { background: #e8f0fe; color: #1a56db; }

  /* Galeri */
  .galeri-section { margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--clr-border); }
  .galeri-title { font-size: 0.85rem; font-family: var(--font-sans); text-transform: uppercase; letter-spacing: 0.08em; color: var(--clr-primary); margin-bottom: 1rem; }
  .galeri-slideshow { border-radius: var(--radius); overflow: hidden; background: var(--clr-primary-dark); }
  .galeri-slide { display: none; width: 100%; }
  .galeri-slide.active { display: block; }
  .galeri-slide img { width: 100%; height: 320px; object-fit: cover; display: block; }
  @media (max-width: 640px) { .galeri-slide img { height: 220px; } }
  .galeri-controls { display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 0.75rem; background: rgba(0,0,0,0.05); }
  .galeri-btn { width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--clr-border); background: var(--clr-surface); font-size: 1.1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; line-height: 1; }
  .galeri-btn:hover { background: var(--clr-primary); color: #fff; border-color: var(--clr-primary); }
  .galeri-dots { display: flex; gap: 0.4rem; }
  .galeri-dot { width: 8px; height: 8px; border-radius: 50%; border: none; background: var(--clr-border); cursor: pointer; padding: 0; transition: all 0.2s; }
  .galeri-dot.active { background: var(--clr-primary); width: 20px; border-radius: 4px; }

  /* Sidebar */
  .sidebar-card { background: var(--clr-surface); border: 1px solid var(--clr-border); border-radius: var(--radius); padding: 1.25rem; margin-top: 1rem; }
  .sidebar-card:first-child { margin-top: 2rem; }
  .sidebar-card h3 { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--clr-primary); margin-bottom: 0.75rem; font-family: var(--font-sans); }
  .sidebar-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .sidebar-card p { font-size: 0.88rem; color: var(--clr-text-muted); margin-bottom: 0.3rem; }
  .keunggulan-list li { font-size: 0.88rem; color: var(--clr-text-muted); }
  .website-link { color: var(--clr-primary); font-size: 0.88rem; word-break: break-all; text-decoration: underline; }
</style>