---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pkbmList = (await getCollection('pkbm-profil'))
  .sort((a, b) => a.data.tahunBerdiri - b.data.tahunBerdiri);

const provinsis = [...new Set(pkbmList.map(p => p.data.provinsi))].sort();
---

<BaseLayout
  title="Profil PKBM Sunnah"
  description="Profil PKBM Sunnah yang telah berhasil beroperasi di berbagai daerah Indonesia."
>
  <div class="page-hero">
    <div class="container">
      <h1>Profil PKBM Sunnah</h1>
      <p>Mengenal lembaga-lembaga yang telah berhasil menjalankan PKBM berbasis nilai Islam dan Sunnah</p>
    </div>
  </div>

  <section>
    <div class="container">
      {pkbmList.length === 0 ? (
        <div class="empty-state">
          <p>📋 Profil PKBM segera ditambahkan.</p>
        </div>
      ) : (
        <>
          <div class="filter-bar">
            <input id="search" type="text" placeholder="Cari nama PKBM atau kota..." />
            <select id="filter-provinsi">
              <option value="">Semua Provinsi</option>
              {provinsis.map(p => <option value={p}>{p}</option>)}
            </select>
            <select id="filter-kota">
              <option value="">Semua Kota</option>
            </select>
            <select id="filter-status">
              <option value="">Semua Status</option>
              <option value="PKBM Mandiri - Akreditasi A">PKBM Mandiri - Akreditasi A</option>
              <option value="PKBM Mandiri - Akreditasi B">PKBM Mandiri - Akreditasi B</option>
              <option value="PKBM Mandiri - Akreditasi C">PKBM Mandiri - Akreditasi C</option>
              <option value="PKBM Mandiri - Belum Akreditasi">PKBM Mandiri - Belum Akreditasi</option>
              <option value="Menginduk">Menginduk</option>
              <option value="Homeschooling">Homeschooling</option>
            </select>
            <span id="result-count"></span>
          </div>

          <div class="pkbm-grid" id="pkbm-grid">
            {pkbmList.map(pkbm => (
              <a href={`/profil-pkbm/${pkbm.slug}`} class="pkbm-card"
                data-nama={pkbm.data.nama.toLowerCase()}
                data-kota={pkbm.data.kota.toLowerCase()}
                data-provinsi={pkbm.data.provinsi}
                data-status={pkbm.data.status}
              >
                <div class="pkbm-thumb">
                  {pkbm.data.image
                    ? <img src={pkbm.data.image} alt={pkbm.data.nama} loading="lazy" decoding="async" />
                    : <div class="pkbm-thumb-placeholder">{pkbm.data.kota}</div>
                  }
                </div>
                <div class="pkbm-body">
                  <div class="pkbm-header">
                    <h2>{pkbm.data.nama}</h2>
                    <span class="pkbm-year">Est. {pkbm.data.tahunBerdiri}</span>
                  </div>
                  <div class="pkbm-location">📍 {pkbm.data.kota}, {pkbm.data.provinsi}</div>
                  <div class="pkbm-status-row">
                    {pkbm.data.status && (
                      <span class={`status-badge status-${pkbm.data.status === 'PKBM Mandiri - Akreditasi A' ? 'akreditasi-a' : pkbm.data.status === 'PKBM Mandiri - Akreditasi B' ? 'akreditasi-b' : pkbm.data.status === 'PKBM Mandiri - Akreditasi C' ? 'akreditasi-c' : pkbm.data.status === 'PKBM Mandiri - Belum Akreditasi' ? 'belum-akreditasi' : pkbm.data.status === 'Menginduk' ? 'menginduk' : 'homeschooling'}`}>
                        {pkbm.data.status}
                      </span>
                    )}
                  </div>
                  <div class="pkbm-programs">
                    {pkbm.data.program.map(p => <span class="tag">{p}</span>)}
                  </div>
                  <span class="read-more">Lihat profil lengkap →</span>
                </div>
              </a>
            ))}
          </div>

          <div id="no-result" class="no-result" style="display:none">
            Tidak ada PKBM yang sesuai filter.
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function() {
  const cards     = document.querySelectorAll('.pkbm-card');
  const search    = document.getElementById('search');
  const selProv   = document.getElementById('filter-provinsi');
  const selKota   = document.getElementById('filter-kota');
  const selStatus = document.getElementById('filter-status');
  const count     = document.getElementById('result-count');
  const noResult  = document.getElementById('no-result');

  function populateKota(prov) {
    const kotas = [...new Set(
      [...cards]
        .filter(c => !prov || c.dataset.provinsi === prov)
        .map(c => c.dataset.kota)
    )].sort();
    selKota.innerHTML = '<option value="">Semua Kota</option>';
    kotas.forEach(k => selKota.innerHTML += `<option value="${k}">${k.charAt(0).toUpperCase()+k.slice(1)}</option>`);
  }
  populateKota('');

  function filter() {
    const q      = search.value.toLowerCase();
    const prov   = selProv.value;
    const kota   = selKota.value.toLowerCase();
    const status = selStatus.value;
    let visible  = 0;

    cards.forEach(card => {
      const match =
        (!q      || card.dataset.nama.includes(q) || card.dataset.kota.includes(q)) &&
        (!prov   || card.dataset.provinsi === prov) &&
        (!kota   || card.dataset.kota === kota) &&
        (!status || card.dataset.status === status);

      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    count.textContent = visible + ' PKBM ditemukan';
    noResult.style.display = visible === 0 ? 'block' : 'none';
  }

  selProv.addEventListener('change', function() { populateKota(this.value); filter(); });
  search.addEventListener('input', filter);
  selKota.addEventListener('change', filter);
  selStatus.addEventListener('change', filter);

  filter();
})();
</script>

<style>
  .page-hero {
    background: var(--clr-primary);
    color: #fff;
    padding: 3rem 0 2.5rem;
  }
  .page-hero h1 { color: #fff; font-size: clamp(1.8rem, 4vw, 2.8rem); }
  .page-hero p { color: rgba(255,255,255,0.8); margin-top: 0.5rem; }

  section { padding: 2.5rem 0; }

  .empty-state { text-align: center; padding: 4rem; color: var(--clr-text-muted); font-size: 1.1rem; }

  .filter-bar {
    display: flex; flex-wrap: wrap;
    gap: 0.75rem; margin-bottom: 1.5rem; align-items: center;
  }
  .filter-bar input, .filter-bar select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    background: var(--clr-surface);
    color: var(--clr-text);
  }
  .filter-bar input { flex: 1; min-width: 180px; }
  #result-count { font-size: 0.85rem; color: var(--clr-text-muted); margin-left: auto; }

  .pkbm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .no-result { text-align: center; color: var(--clr-text-muted); padding: 3rem; font-size: 0.95rem; }

  .pkbm-card {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: all 0.2s;
    text-decoration: none;
  }
  .pkbm-card:hover { border-color: var(--clr-primary); box-shadow: var(--shadow-md); transform: translateY(-3px); }

  .pkbm-thumb { width: 100%; height: 180px; overflow: hidden; flex-shrink: 0; }
  .pkbm-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .pkbm-card:hover .pkbm-thumb img { transform: scale(1.05); }
  .pkbm-thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));
    color: rgba(255,255,255,0.6);
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
  }

  .pkbm-body { padding: 1.25rem 1.5rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .pkbm-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }
  .pkbm-body h2 { font-size: 1rem; margin: 0; line-height: 1.35; }
  .pkbm-year { background: var(--clr-accent-light); color: #7a5c00; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
  .pkbm-location { font-size: 0.8rem; color: var(--clr-text-muted); }

  .pkbm-status-row { display: flex; }
  .status-badge { display: inline-block; padding: 0.25rem 0.7rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
  .status-akreditasi-a { background: #d4edda; color: #155724; }
  .status-akreditasi-b { background: #fff3cd; color: #856404; }
  .status-akreditasi-c { background: #f8d7da; color: #721c24; }
  .status-belum-akreditasi { background: #e2e3e5; color: #383d41; }
  .status-mandiri { background: var(--clr-primary-light); color: var(--clr-primary); }
  .status-menginduk { background: var(--clr-accent-light); color: #7a5c00; }
  .status-homeschooling { background: #e8f0fe; color: #1a56db; }

  .pkbm-programs { display: flex; flex-wrap: wrap; gap: 0.35rem; flex: 1; align-content: flex-start; }
  .read-more { font-size: 0.82rem; font-weight: 600; color: var(--clr-primary); margin-top: auto; }

  @media (max-width: 640px) {
    .filter-bar input { min-width: 100%; }
    #result-count { margin-left: 0; }
  }
</style>